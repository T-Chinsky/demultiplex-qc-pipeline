/*
========================================================================================
    BCL Convert + QC Pipeline Configuration
========================================================================================
*/

// Global default params
params {
    // Input/output options
    samplesheet = null
    run_dir = null
    outdir = './results'
    fastq_screen_config = null

    // BCL Convert options
    bcl_sampleproject_subdirectories = false
    no_lane_splitting = false

    // Process resource defaults
    max_cpus = 32
    max_memory = '256.GB'
    max_time = '24.h'
}

// Process labels for resource allocation
process {
    // Default resources
    cpus = 1
    memory = 4.GB
    time = 2.h

    withLabel: process_low {
        cpus = 2
        memory = 8.GB
        time = 4.h
    }

    withLabel: process_medium {
        cpus = 8
        memory = 32.GB
        time = 8.h
    }

    withLabel: process_high {
        cpus = 32
        memory = 256.GB
        time = 24.h
    }

    // Process-specific publishing directories
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: 'copy',
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]
}

// Container engine configuration
docker {
    enabled = true
    runOptions = '-u $(id -u):$(id -g)'
}

singularity {
    enabled = false
    autoMounts = true
}

// Execution profiles
profiles {
    standard {
        process.executor = 'local'
    }

    docker {
        docker.enabled = true
        singularity.enabled = false
    }

    singularity {
        singularity.enabled = true
        docker.enabled = false
    }

    slurm {
        process {
            executor = 'slurm'
            queue = 'gbc'
            clusterOptions = '--account=gbcstaff --qos=gbc --cluster=faculty'
        }
        executor {
            queueSize = 50
            submitRateLimit = '10 sec'
        }
    }

    test {
        params {
            outdir = './test_results'
            max_cpus = 4
            max_memory = '16.GB'
            max_time = '2.h'
        }
    }
}

// Manifest
manifest {
    name = 'BCL Convert + QC Pipeline'
    author = 'Seqera AI'
    description = 'Demultiplex Illumina BCL files and perform comprehensive quality control'
    mainScript = 'main.nf'
    nextflowVersion = '>=25.04.0'
    version = '1.0.0'
}

// Trace and report options
timeline {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_timeline.html"
}

report {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_report.html"
}

trace {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_trace.txt"
}

dag {
    enabled = true
    file = "${params.outdir}/pipeline_info/pipeline_dag.svg"
}

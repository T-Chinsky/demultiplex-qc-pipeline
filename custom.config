// Custom configuration template for HPC cluster execution
// Usage: nextflow run main.nf -c custom.config --input runs.csv
//
// Instructions:
// 1. Copy this file and modify for your specific cluster
// 2. Update paths to match your cluster's storage locations
// 3. Adjust SLURM options (partition, account, qos) as needed
// 4. Configure Singularity/Apptainer cache directories

cleanup = true

env {
  // Uncomment and modify for Apptainer/Singularity temp directories
  // APPTAINERENV_TMPDIR = '/path/to/singularity/temp/'
  // TMPDIR = '/path/to/temp/'
  // NXF_SINGULARITY_CACHEDIR = '/path/to/singularity/cache/'  
}

singularity {
  autoMounts = true
  // cacheDir = '/path/to/singularity/cache/'
  // runOptions = '-B /path/to/bind/mount/'
  pullTimeout = '2 hours'
}

executor {
    name = "slurm"
    queueSize = 2000
    submitRateLimit = "10/1sec"
    exitReadTimeout = "1000 min"
}

process {
    // Modify these SLURM options to match your cluster's configuration
    // clusterOptions = '--partition <partition_name> --account <account_name> --qos <qos_name>'
    maxRetries     = 10
    
    // Clean up job names for SLURM compatibility ([] and " " not allowed)
    executor.jobName = { task.name.replace("[", "(").replace("]", ")").replace(" ", "_") }
}

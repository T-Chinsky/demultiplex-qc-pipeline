/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines test-specific configuration and profiles
----------------------------------------------------------------------------------------
*/

// Disable automatic cleanup of work directory for test inspection
cleanup = false

// Set deterministic settings for reproducible tests
timeline.enabled = false
report.enabled = false
trace.enabled = false
dag.enabled = false

profiles {
    test {
        params {
            config_profile_name        = 'Test profile'
            config_profile_description = 'Minimal test dataset to check pipeline function'
            
            // Limit resources for quick testing
            max_cpus   = 2
            max_memory = '6.GB'
            max_time   = '6.h'
            
            // Skip time-consuming QC steps for speed
            skip_fastq_screen = true
        }
    }
    
    test_full {
        params {
            config_profile_name        = 'Full test profile'
            config_profile_description = 'Full test dataset with all QC modules enabled'
            
            // More resources for comprehensive testing
            max_cpus   = 4
            max_memory = '12.GB'
            max_time   = '12.h'
            
            // Enable all QC modules
            skip_fastqc       = false
            skip_multiqc      = false
            skip_fastq_screen = false
        }
    }
    
    docker {
        docker.enabled         = true
        docker.userEmulation   = true
        singularity.enabled    = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
    }
    
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
    }
}

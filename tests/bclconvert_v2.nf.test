nextflow_pipeline {
    name "Test BCLConvert v2 specific features"
    script "../main.nf"
    tag "bclconvert"
    tag "v2"

    test("BCLConvert v2 - With FastQC and MultiQC") {
        
        when {
            params {
                outdir        = "$outputDir"
                input         = "${projectDir}/tests/data/v2/samplesheet.csv"
                demultiplexer = 'bclconvert'
                
                // Enable QC modules
                skip_fastqc       = false
                skip_multiqc      = false
                skip_fastq_screen = true
                
                // Resource limits
                max_cpus   = 2
                max_memory = '6.GB'
                max_time   = '6.h'
            }
        }

        then {
            assert workflow.success
            assert workflow.trace.succeeded().size() > 0
            
            // Verify FastQC ran
            assert workflow.trace.tasks().any { task -> 
                task.process == 'NFCORE_DEMULTIPLEX:DEMULTIPLEX:BCL_QC_SINGLE_RUN:FASTQC'
            }
            
            // Verify MultiQC ran
            assert workflow.trace.tasks().any { task -> 
                task.process == 'NFCORE_DEMULTIPLEX:DEMULTIPLEX:MULTIQC'
            }
            
            def stable_name = getAllFilesFromDir(
                params.outdir, 
                relative: true, 
                includeDir: true, 
                ignore: ['pipeline_info/*.{html,json,txt,svg}', '*.log']
            )
            
            assert snapshot(
                workflow.trace.succeeded().size(),
                stable_name
            ).match()
        }
    }

    test("BCLConvert v2 - Skip FastQC") {
        
        when {
            params {
                outdir        = "$outputDir"
                input         = "${projectDir}/tests/data/v2/samplesheet.csv"
                demultiplexer = 'bclconvert'
                
                // Skip FastQC, keep MultiQC
                skip_fastqc       = true
                skip_multiqc      = false
                skip_fastq_screen = true
                
                max_cpus   = 2
                max_memory = '6.GB'
                max_time   = '6.h'
            }
        }

        then {
            assert workflow.success
            assert workflow.trace.succeeded().size() > 0
            
            // Verify FastQC did NOT run
            assert !workflow.trace.tasks().any { task -> 
                task.process == 'NFCORE_DEMULTIPLEX:DEMULTIPLEX:BCL_QC_SINGLE_RUN:FASTQC'
            }
            
            // Verify MultiQC still ran
            assert workflow.trace.tasks().any { task -> 
                task.process == 'NFCORE_DEMULTIPLEX:DEMULTIPLEX:MULTIQC'
            }
        }
    }

    test("BCLConvert v2 - Skip MultiQC") {
        
        when {
            params {
                outdir        = "$outputDir"
                input         = "${projectDir}/tests/data/v2/samplesheet.csv"
                demultiplexer = 'bclconvert'
                
                // Keep FastQC, skip MultiQC
                skip_fastqc       = false
                skip_multiqc      = true
                skip_fastq_screen = true
                
                max_cpus   = 2
                max_memory = '6.GB'
                max_time   = '6.h'
            }
        }

        then {
            assert workflow.success
            assert workflow.trace.succeeded().size() > 0
            
            // Verify FastQC ran
            assert workflow.trace.tasks().any { task -> 
                task.process == 'NFCORE_DEMULTIPLEX:DEMULTIPLEX:BCL_QC_SINGLE_RUN:FASTQC'
            }
            
            // Verify MultiQC did NOT run
            assert !workflow.trace.tasks().any { task -> 
                task.process == 'NFCORE_DEMULTIPLEX:DEMULTIPLEX:MULTIQC'
            }
        }
    }

    test("BCLConvert v2 - Custom override_cycles") {
        
        when {
            params {
                outdir          = "$outputDir"
                input           = "${projectDir}/tests/data/v2/samplesheet.csv"
                demultiplexer   = 'bclconvert'
                override_cycles = 'Y151;I8N2;I8N2;Y151'
                
                skip_fastqc       = true
                skip_multiqc      = true
                skip_fastq_screen = true
                
                max_cpus   = 2
                max_memory = '6.GB'
                max_time   = '6.h'
            }
        }

        then {
            assert workflow.success
            assert workflow.trace.succeeded().size() > 0
            
            // Verify BCLConvert ran with custom cycles
            assert workflow.trace.tasks().any { task -> 
                task.process == 'NFCORE_DEMULTIPLEX:DEMULTIPLEX:BCL_QC_SINGLE_RUN:BCLCONVERT'
            }
        }
    }

    test("BCLConvert v2 - stub") {
        
        options "-stub"
        tag "stub"
        
        when {
            params {
                outdir        = "$outputDir"
                input         = "${projectDir}/tests/data/v2/samplesheet.csv"
                demultiplexer = 'bclconvert'
                
                skip_fastqc       = false
                skip_multiqc      = false
                skip_fastq_screen = true
                
                max_cpus   = 2
                max_memory = '6.GB'
                max_time   = '6.h'
            }
        }

        then {
            assert workflow.success
            assert workflow.trace.succeeded().size() > 0
        }
    }
}
